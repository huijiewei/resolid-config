{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "noEmit": true,

    "target": "es2022",

    "isolatedModules": true,
    "erasableSyntaxOnly": true,

    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "lib": ["es2022", "dom"]
  }
}
